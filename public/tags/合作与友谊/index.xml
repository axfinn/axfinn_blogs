    <item>
      <title>森林里的音乐会 —— 合作与友谊</title>
      <link>https://blog.jaxiu.cn/blog/2026-03/%E6%A3%AE%E6%9E%97%E9%87%8C%E7%9A%84%E9%9F%B3%E4%B9%90%E4%BC%9A-%E5%90%88%E4%BD%9C%E4%B8%8E%E5%8F%8B%E8%B0%8A/</link>
